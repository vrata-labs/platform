{
  "name": "noah",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.0.0",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.13.10",
    "playwright": "^1.58.2",
    "typescript": "^5.8.2"
  },
  "scripts": {
    "dev": "pnpm -r --if-present dev",
    "build": "pnpm -r --if-present build",
    "lint": "pnpm -r --if-present lint",
    "test": "pnpm -r --if-present test && node --test tools/*.test.mjs",
    "typecheck": "pnpm -r --if-present typecheck",
    "test:m0.5": "pnpm run lint && pnpm run typecheck && pnpm run build && pnpm run test && pnpm exec playwright test tests/e2e/m0.5 --workers=1",
    "validate:avatars": "pnpm --filter @noah/asset-pipeline build && pnpm --filter @noah/asset-pipeline validate:avatars",
    "test:e2e": "playwright test --grep-invert @staging",
    "test:e2e:staging": "BASE_URL=\"${BASE_URL:-https://89.169.161.91.sslip.io}\" PLAYWRIGHT_NO_WEB_SERVER=1 playwright test --grep @staging",
    "test:e2e:rutube": "BASE_URL=\"${BASE_URL:-https://89.169.161.91.sslip.io}\" PLAYWRIGHT_NO_WEB_SERVER=1 playwright test --grep @rutube --workers=1",
    "xr:telemetry": "node tools/xr-telemetry.mjs",
    "xr:telemetry:blueoffice": "XR_ROOM_ID=\"${XR_ROOM_ID:-0b537d34-7b92-4b51-854a-8c64cfb4c114}\" node tools/xr-telemetry.mjs"
  }
}
