{
  "name": "@vrata/asset-pipeline",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "vrata": "./bin/vrata.mjs",
    "vrata-asset-validate": "./bin/vrata.mjs"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "scenes:validate": "node dist/cli.js scenes validate",
    "validate:sample": "node dist/cli.js --file sample.glb --ext .glb --size-mb 12",
    "validate:avatars": "node dist/cli.js --avatar-catalog ../../apps/runtime-web/public/assets/avatars/catalog.v1.json --avatar-recipes ../../apps/runtime-web/public/assets/avatars/avatar-recipes.v1.json",
    "test": "node --test dist/**/*.test.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
