# Runtime
RUNTIME_BASE_URL=http://localhost:3000

# API
API_PORT=4000
API_PUBLIC_URL=http://localhost:4000
API_CORS_ORIGIN=*
STATE_TOKEN_TTL_SECONDS=900
MEDIA_TOKEN_TTL_SECONDS=900
XR_ENABLED=true
FEATURE_XR=true
FEATURE_VOICE=true
FEATURE_SCREEN_SHARE=true
SPATIAL_AUDIO_ENABLED=true
FEATURE_SPATIAL_AUDIO=true
FEATURE_ROOM_STATE_REALTIME=true
FEATURE_REMOTE_DIAGNOSTICS=true
FEATURE_DOCUMENTS=true
DOCUMENT_UPLOAD_MAX_BYTES=10485760
PDF_PRESENTATION_MAX_PAGES=250

# Room state
ROOM_STATE_PORT=2567
ROOM_STATE_PUBLIC_URL=ws://localhost:2567
ROOM_STATE_INTERNAL_URL=http://localhost:2567

# LiveKit
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
LIVEKIT_ROOM_PREFIX=vrata-

# Control plane
CONTROL_PLANE_PUBLIC_URL=http://localhost:3001
CONTROL_PLANE_ADMIN_TOKEN=dev-admin-token

# Infra
POSTGRES_URL=postgres://postgres:postgres@localhost:5432/vrata
OBJECT_STORAGE_BUCKET=vrata-dev
YC_FOLDER_ID=
YC_CLOUD_ID=
