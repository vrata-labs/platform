COMPOSE_PROJECT_NAME=vrata
API_IMAGE_REPO=ghcr.io/psilon2000/vrata-api
ROOM_STATE_IMAGE_REPO=ghcr.io/psilon2000/vrata-room-state
REMOTE_BROWSER_IMAGE_REPO=ghcr.io/psilon2000/vrata-remote-browser
IMAGE_TAG=0.1.0

# Public endpoints for local evaluation.
VRATA_APP_BASE_URL=http://127.0.0.1:4000
ROOM_STATE_PUBLIC_URL=ws://127.0.0.1:2567
LIVEKIT_URL=ws://127.0.0.1:7880
REMOTE_BROWSER_PUBLIC_URL=ws://127.0.0.1:4010
VRATA_LIVEKIT_DOMAIN=127.0.0.1
LIVEKIT_NODE_IP=127.0.0.1

# Published ports.
VRATA_HTTP_PORT=4000
VRATA_API_DIRECT_PORT=4001
VRATA_ROOM_STATE_PORT=2567
VRATA_LIVEKIT_PORT=7880
VRATA_LIVEKIT_UDP_PORT=7881
VRATA_REMOTE_BROWSER_PORT=4010
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# API / control plane. Replace every CHANGE_ME value before exposing a host.
API_PORT=4000
API_CORS_ORIGIN=*
CONTROL_PLANE_ADMIN_TOKEN=CHANGE_ME_control_plane_admin_token
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
LIVEKIT_ROOM_PREFIX=vrata-
STATE_TOKEN_TTL_SECONDS=900
STATE_TOKEN_SECRET=CHANGE_ME_state_token_secret
REMOTE_BROWSER_TOKEN_SECRET=CHANGE_ME_remote_browser_token_secret
REMOTE_BROWSER_TOKEN_TTL_SECONDS=300
VRATA_INTERNAL_SERVICE_TOKEN=CHANGE_ME_internal_service_token
VRATA_DEV_ROLE_QUERY=true
MEDIA_TOKEN_TTL_SECONDS=900
REMOTE_BROWSER_ALLOWED_ORIGINS=http://127.0.0.1:4000,http://localhost:4000
REMOTE_BROWSER_ALLOW_PRIVATE_ALLOWED_ORIGINS=true
REMOTE_BROWSER_FRAME_INTERVAL_MS=250

# Postgres.
POSTGRES_DB=vrata
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_postgres_password
POSTGRES_URL=postgres://postgres:CHANGE_ME_postgres_password@postgres:5432/vrata

# MinIO / scene bundles.
MINIO_ROOT_USER=CHANGE_ME_minio_user
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_password
MINIO_BUCKET=vrata-scene-bundles
MINIO_PUBLIC_BASE_URL=http://127.0.0.1:9000
MINIO_SCENE_PREFIX=scenes/
SCENE_BUNDLE_PROVIDER=minio-default
SCENE_BUNDLE_S3_ENDPOINT=
SCENE_BUNDLE_S3_REGION=
SCENE_BUNDLE_S3_BUCKET=
SCENE_BUNDLE_S3_PUBLIC_BASE_URL=

# Compose support files.
CADDY_CONFIG_FILE=./Caddyfile.selfhost
