COMPOSE_PROJECT_NAME=vrata-production
API_IMAGE_REPO=ghcr.io/psilon2000/vrata-api
ROOM_STATE_IMAGE_REPO=ghcr.io/psilon2000/vrata-room-state
REMOTE_BROWSER_IMAGE_REPO=ghcr.io/psilon2000/vrata-remote-browser
IMAGE_TAG=0.1.0

# Production mode is mandatory for compose.production.yml preflight.
VRATA_DEPLOYMENT_MODE=production

# Public domains served by Caddy. Replace every example hostname.
VRATA_APP_DOMAIN=app.example.com
VRATA_STATE_DOMAIN=state.example.com
VRATA_LIVEKIT_DOMAIN=livekit.example.com
VRATA_STORAGE_DOMAIN=storage.example.com
LIVEKIT_NODE_IP=REPLACE_WITH_LIVEKIT_NODE_IP

# Public URLs reachable by browsers. Production preflight rejects public http:// and ws:// URLs.
VRATA_APP_BASE_URL=https://app.example.com
CONTROL_PLANE_PUBLIC_URL=https://app.example.com/control-plane
ROOM_STATE_PUBLIC_URL=wss://state.example.com
LIVEKIT_URL=wss://livekit.example.com
MINIO_PUBLIC_BASE_URL=https://storage.example.com
VRATA_ALLOW_INSECURE_PRODUCTION_URLS=false

# Published ports. HTTP is kept for ACME redirects; app traffic should use HTTPS.
VRATA_HTTP_PORT=80
VRATA_HTTPS_PORT=443
VRATA_LIVEKIT_TCP_PORT=7881
VRATA_LIVEKIT_UDP_PORT=7882
LIVEKIT_TURN_ENABLED=false
LIVEKIT_TURN_DOMAIN=turn.example.com
LIVEKIT_TURN_TLS_PORT=5349
LIVEKIT_TURN_UDP_PORT=3478
LIVEKIT_TURN_RELAY_RANGE_START=50000
LIVEKIT_TURN_RELAY_RANGE_END=50100
LIVEKIT_TURN_EXTERNAL_TLS=true
LIVEKIT_TURN_CERT_FILE=
LIVEKIT_TURN_KEY_FILE=

# API / control plane. Replace all REPLACE_WITH values before startup.
API_PORT=4000
API_CORS_ORIGIN=https://app.example.com
CONTROL_PLANE_ADMIN_TOKEN=REPLACE_WITH_32_PLUS_RANDOM_CHARS_CONTROL_PLANE_TOKEN
LIVEKIT_API_KEY=REPLACE_WITH_LIVEKIT_API_KEY
LIVEKIT_API_SECRET=REPLACE_WITH_32_PLUS_RANDOM_CHARS_LIVEKIT_SECRET
LIVEKIT_ROOM_PREFIX=vrata-
STATE_TOKEN_TTL_SECONDS=900
STATE_TOKEN_SECRET=REPLACE_WITH_32_PLUS_RANDOM_CHARS_STATE_TOKEN_SECRET
VRATA_INTERNAL_SERVICE_TOKEN=REPLACE_WITH_32_PLUS_RANDOM_CHARS_INTERNAL_SERVICE_TOKEN
REMOTE_BROWSER_INTERNAL_TOKEN=REPLACE_WITH_32_PLUS_RANDOM_CHARS_REMOTE_BROWSER_INTERNAL_TOKEN
VRATA_DEV_ROLE_QUERY=false
MEDIA_TOKEN_TTL_SECONDS=900

# Experimental services are disabled by default in production.
REMOTE_BROWSER_ENABLED=false
VRATA_ALLOW_EXPERIMENTAL_SERVICES=false
REMOTE_BROWSER_PUBLIC_URL=wss://app.example.com
REMOTE_BROWSER_ALLOWED_ORIGINS=
REMOTE_BROWSER_TOKEN_SECRET=
REMOTE_BROWSER_TOKEN_TTL_SECONDS=300
REMOTE_BROWSER_MAX_SESSIONS=2
REMOTE_BROWSER_SESSION_TTL_SECONDS=900
REMOTE_BROWSER_CPU_LIMIT=2.0
REMOTE_BROWSER_MEMORY_LIMIT=2g
REMOTE_BROWSER_PIDS_LIMIT=512

# Postgres.
POSTGRES_DB=vrata
POSTGRES_USER=vrata
POSTGRES_PASSWORD=REPLACE_WITH_16_PLUS_RANDOM_CHARS_POSTGRES_PASSWORD
POSTGRES_URL=postgres://vrata:REPLACE_WITH_16_PLUS_RANDOM_CHARS_POSTGRES_PASSWORD@postgres:5432/vrata

# MinIO / scene bundles.
MINIO_ROOT_USER=REPLACE_WITH_MINIO_ROOT_USER
MINIO_ROOT_PASSWORD=REPLACE_WITH_16_PLUS_RANDOM_CHARS_MINIO_PASSWORD
MINIO_BUCKET=vrata-scene-bundles
MINIO_SCENE_PREFIX=scenes/
SCENE_BUNDLE_PROVIDER=minio-default
SCENE_BUNDLE_S3_ENDPOINT=
SCENE_BUNDLE_S3_REGION=
SCENE_BUNDLE_S3_BUCKET=
SCENE_BUNDLE_S3_PUBLIC_BASE_URL=

# Compose support files.
CADDY_CONFIG_FILE=./Caddyfile.production
