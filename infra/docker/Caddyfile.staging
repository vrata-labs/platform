{
  servers {
    protocols h1 h2
  }
}

{$NOAH_APP_DOMAIN} {
  handle /assets/scenes/* {
    root * /srv/runtime-public
    header Access-Control-Allow-Origin *
    file_server
  }

  reverse_proxy api:4000
}

{$NOAH_STATE_DOMAIN} {
  handle /assets/scenes/* {
    root * /srv/runtime-public
    header Access-Control-Allow-Origin *
    file_server
  }

  reverse_proxy room-state:2567
}

{$NOAH_LIVEKIT_DOMAIN} {
  reverse_proxy livekit:7880
}
