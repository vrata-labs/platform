COMPOSE_PROJECT_NAME=vrata
API_IMAGE_REPO=vrata-api
ROOM_STATE_IMAGE_REPO=vrata-room-state
REMOTE_BROWSER_IMAGE_REPO=vrata-remote-browser
IMAGE_TAG=latest

# Public endpoints
VRATA_APP_BASE_URL=http://127.0.0.1:4000
VRATA_APP_DOMAIN=localhost
VRATA_STATE_DOMAIN=state.localhost
VRATA_LIVEKIT_DOMAIN=livekit.localhost
VRATA_BROWSER_DOMAIN=browser.localhost
LIVEKIT_NODE_IP=127.0.0.1
ROOM_STATE_PUBLIC_URL=ws://127.0.0.1:2567
LIVEKIT_URL=ws://127.0.0.1:7880
VRATA_ALLOW_INSECURE_PRODUCTION_URLS=true
REMOTE_BROWSER_PUBLIC_URL=ws://127.0.0.1:4010
REMOTE_BROWSER_ALLOWED_ORIGINS=http://127.0.0.1:4000,http://localhost:4000,https://rutube.ru,https://*.rutube.ru,https://*.rtbcdn.ru
REMOTE_BROWSER_ALLOW_PRIVATE_ALLOWED_ORIGINS=true
REMOTE_BROWSER_FRAME_INTERVAL_MS=250

# Published ports
VRATA_HTTP_PORT=4000
VRATA_HTTPS_PORT=4443
VRATA_API_DIRECT_PORT=4001
VRATA_ROOM_STATE_PORT=2567
VRATA_LIVEKIT_PORT=7880
VRATA_LIVEKIT_TCP_PORT=7881
VRATA_LIVEKIT_UDP_PORT=7881
LIVEKIT_TURN_ENABLED=true
LIVEKIT_TURN_DOMAIN=turn.localhost
LIVEKIT_TURN_TLS_PORT=5349
LIVEKIT_TURN_UDP_PORT=3478
LIVEKIT_TURN_RELAY_RANGE_START=50000
LIVEKIT_TURN_RELAY_RANGE_END=50100
LIVEKIT_TURN_EXTERNAL_TLS=true
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# API / control plane
API_PORT=4000
API_CORS_ORIGIN=*
CONTROL_PLANE_ADMIN_TOKEN=test-admin-token
LIVEKIT_API_KEY=vrata-stage-local
LIVEKIT_API_SECRET=local-livekit-secret-0123456789abcdef
LIVEKIT_ROOM_PREFIX=vrata-
STATE_TOKEN_TTL_SECONDS=900
STATE_TOKEN_SECRET=dev-state-secret
REMOTE_BROWSER_TOKEN_SECRET=dev-remote-browser-secret
REMOTE_BROWSER_TOKEN_TTL_SECONDS=300
VRATA_DEV_ROLE_QUERY=true
MEDIA_TOKEN_TTL_SECONDS=900

# Postgres
POSTGRES_DB=vrata
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
POSTGRES_URL=postgres://postgres:postgres@postgres:5432/vrata

# MinIO
MINIO_ROOT_USER=vrataminio
MINIO_ROOT_PASSWORD=vrataminio123
MINIO_BUCKET=vrata-scene-bundles
MINIO_PUBLIC_BASE_URL=http://127.0.0.1:9000
MINIO_SCENE_PREFIX=scenes/
SCENE_BUNDLE_PROVIDER=minio-default
SCENE_BUNDLE_S3_ENDPOINT=
SCENE_BUNDLE_S3_REGION=
SCENE_BUNDLE_S3_BUCKET=
SCENE_BUNDLE_S3_PUBLIC_BASE_URL=

# Compose support files
CADDY_CONFIG_FILE=./Caddyfile.local
