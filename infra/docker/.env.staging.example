COMPOSE_PROJECT_NAME=noah
API_IMAGE_REPO=noah-api
ROOM_STATE_IMAGE_REPO=noah-room-state
IMAGE_TAG=latest

# Public endpoints
NOAH_APP_BASE_URL=http://127.0.0.1:4000
NOAH_APP_DOMAIN=localhost
NOAH_STATE_DOMAIN=state.localhost
NOAH_LIVEKIT_DOMAIN=livekit.localhost
ROOM_STATE_PUBLIC_URL=ws://127.0.0.1:2567
LIVEKIT_URL=ws://127.0.0.1:7880

# Published ports
NOAH_HTTP_PORT=4000
NOAH_HTTPS_PORT=4443
NOAH_API_DIRECT_PORT=4001
NOAH_ROOM_STATE_PORT=2567
NOAH_LIVEKIT_PORT=7880
NOAH_LIVEKIT_UDP_PORT=7881
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# API / control plane
API_PORT=4000
API_CORS_ORIGIN=*
CONTROL_PLANE_ADMIN_TOKEN=test-admin-token
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
LIVEKIT_ROOM_PREFIX=noah-
STATE_TOKEN_TTL_SECONDS=900
MEDIA_TOKEN_TTL_SECONDS=900
FEATURE_AVATAR_LEG_IK=false

# Postgres
POSTGRES_DB=noah
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
POSTGRES_URL=postgres://postgres:postgres@postgres:5432/noah

# MinIO
MINIO_ROOT_USER=noahminio
MINIO_ROOT_PASSWORD=noahminio123
MINIO_BUCKET=noah-scene-bundles
MINIO_PUBLIC_BASE_URL=http://127.0.0.1:9000
MINIO_SCENE_PREFIX=scenes/
SCENE_BUNDLE_PROVIDER=minio-default
SCENE_BUNDLE_S3_ENDPOINT=
SCENE_BUNDLE_S3_REGION=
SCENE_BUNDLE_S3_BUCKET=
SCENE_BUNDLE_S3_PUBLIC_BASE_URL=

# Compose support files
CADDY_CONFIG_FILE=./Caddyfile.local
